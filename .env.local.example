# Copy to .env.local and fill in.
# Firebase public client config goes directly in app/lib/firebase.ts (same pattern as rinkproducts-web).

# Resend (leave blank until ayni-studios.com domain is verified in Resend)
RESEND_API_KEY=
RESEND_FROM="Ayni Studios <humanity@ayni-studios.com>"
ADMIN_EMAIL=humanity@ayni-studios.com

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Billing (framework only; not deployed yet) --------------------
# Stripe (new account under studiosayni@gmail.com — use sk_test_... in dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Public pay-page contact details
NEXT_PUBLIC_ZELLE_CONTACT=studiosayni@gmail.com

# Guards the /api/admin/* routes. Generate a long random string and share
# between the admin UI (entered via browser prompt, stored in localStorage)
# and the server. Rotate by updating this value; the admin UI will re-prompt.
ADMIN_API_KEY=
